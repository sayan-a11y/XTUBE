generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  email     String   @unique
  avatar    String?
  role      String   @default("user") // user, admin
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  comments   Comment[]
  bookmarks  Bookmark[]
  history    History[]
  watchProgress WatchProgress[]
}

model Video {
  id          String   @id @default(cuid())
  title       String
  description String?
  thumbnail   String
  videoUrl    String
  category    String
  duration    String   @default("0:00")
  views       Int      @default(0)
  isHd        Boolean  @default(false)
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // ─── OTT Streaming Fields ────────────────────────────────────────────────
  durationSeconds  Int      @default(0)   // exact duration in seconds
  hlsUrl           String?                // HLS master manifest URL (.m3u8)
  dashUrl          String?                // DASH manifest URL (.mpd)
  qualityLevels    String  @default("[]") // JSON: available quality levels ["480p","720p","1080p","2K","4K"]
  fileSize         BigInt  @default(0)    // original file size in bytes
  bitrate          Int     @default(0)    // average bitrate in kbps
  codec            String  @default("h264") // video codec
  audioCodec       String  @default("aac")  // audio codec
  frameRate        Float   @default(30)     // frames per second
  resolution       String  @default("1080p") // max resolution

  // ─── Thumbnail & Preview ─────────────────────────────────────────────────
  thumbnailUrls   String  @default("[]") // JSON: array of auto-generated thumbnail URLs
  previewUrl      String?               // WebVTT preview sprite sheet URL

  // ─── Storage ─────────────────────────────────────────────────────────────
  storageProvider String  @default("local") // local, r2, s3
  storageKey      String?                  // storage object key for provider

  // ─── Mid-roll Ads Timing ────────────────────────────────────────────────
  midrollTimings  String  @default("[]") // JSON: [1800, 3600, 5400] seconds (30min intervals)

  // ─── Subtitles ───────────────────────────────────────────────────────────
  subtitleTracks  String  @default("[]") // JSON: [{lang:"en", label:"English", url:"..."}]

  comments    Comment[]
  bookmarks   Bookmark[]
  history     History[]
  ads         VideoAd[]
  watchProgress WatchProgress[]

  @@index([category])
  @@index([views])
  @@index([createdAt])
}

model Category {
  id    String @id @default(cuid())
  name  String @unique
  slug  String @unique
  icon  String?
  order Int    @default(0)
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  likes     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId  String
  videoId String
  parentId String?

  user    User     @relation(fields: [userId], references: [id])
  video   Video    @relation(fields: [videoId], references: [id])
  parent  Comment? @relation("CommentReplies", fields: [parentId], references: [id])
  replies Comment[] @relation("CommentReplies")

  @@index([videoId])
  @@index([userId])
}

model Ad {
  id          String   @id @default(cuid())
  type        String   // banner, popup, overlay, video
  position    String   // hero, sidebar, footer, entry, exit, timed
  title       String
  imageUrl    String
  linkUrl     String?
  impressions Int      @default(0)
  clicks      Int      @default(0)
  revenue     Float    @default(0)
  isActive    Boolean  @default(true)
  startDate   DateTime?
  endDate     DateTime?
  frequency   Int      @default(1) // how often to show
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // ─── Ad Streaming Fields ────────────────────────────────────────────────
  mediaUrl     String?               // video/GIF ad URL
  mediaFormat  String  @default("jpg") // mp4, webm, mov, jpg, png, webp, gif
  adDuration   Int     @default(0)     // video ad duration in seconds
  skipAfter    Int     @default(5)     // seconds before skip button appears
  quality      String  @default("720p") // ad quality

  videoAds VideoAd[]

  @@index([isActive])
  @@index([type])
  @@index([position])
}

model VideoAd {
  id       String @id @default(cuid())
  adId     String
  videoId  String
  position String // pre-roll, mid-roll, post-roll, overlay
  timing   Int    @default(0) // seconds into video

  ad    Ad    @relation(fields: [adId], references: [id])
  video Video @relation(fields: [videoId], references: [id])
}

model Bookmark {
  id     String @id @default(cuid())
  userId String
  videoId String

  user  User  @relation(fields: [userId], references: [id])
  video Video @relation(fields: [videoId], references: [id])

  @@unique([userId, videoId])
}

model History {
  id        String   @id @default(cuid())
  userId    String
  videoId   String
  progress  Int      @default(0) // percentage watched
  watchedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id])
  video Video @relation(fields: [videoId], references: [id])

  @@unique([userId, videoId])
}

model WatchProgress {
  id             String   @id @default(cuid())
  userId         String
  videoId        String
  position       Int      @default(0)   // last watched position in seconds
  duration       Int      @default(0)   // total duration in seconds
  percentage     Float    @default(0)   // percentage watched (0-100)
  lastWatchedAt  DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id])
  video Video @relation(fields: [videoId], references: [id])

  @@unique([userId, videoId])
  @@index([userId])
  @@index([lastWatchedAt])
}

model HeroAd {
  id           String   @id @default(cuid())
  title        String
  description  String?
  category     String?
  mediaUrl     String
  thumbnailUrl String?
  adType       String   @default("image") // image, video
  mediaFormat  String   @default("jpg")   // mp4, webm, mov, jpg, png, webp
  isActive     Boolean  @default(true)
  displayOrder Int      @default(0)
  impressions  Int      @default(0)
  clicks       Int      @default(0)
  ctr          Float    @default(0)
  startDate    DateTime?
  endDate      DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([isActive])
}

model FooterAd {
  id           String   @id @default(cuid())
  title        String
  mediaUrl     String
  thumbnailUrl String?
  adType       String   @default("image") // image, video, gif, html5
  mediaFormat  String   @default("jpg")   // mp4, webm, mov, jpg, png, webp, gif
  isActive     Boolean  @default(true)
  linkUrl      String?
  impressions  Int      @default(0)
  clicks       Int      @default(0)
  ctr          Float    @default(0)
  startDate    DateTime?
  endDate      DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([isActive])
}

model Analytics {
  id         String   @id @default(cuid())
  date       DateTime @default(now())
  device     String
  country    String   @default("unknown")
  views      Int      @default(0)
  watchTime  Int      @default(0) // total seconds
  revenue    Float    @default(0)
  adClicks   Int      @default(0)
  newUsers   Int      @default(0)
}

model LiveTV {
  id          String   @id @default(cuid())
  title       String
  description String?
  streamUrl   String
  thumbnailUrl String?
  category    String   @default("general")
  isLive      Boolean  @default(false)
  viewers     Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Transaction {
  id          String   @id @default(cuid())
  userId      String?
  type        String   // subscription, payment, refund, withdrawal
  amount      Float
  currency    String   @default("USD")
  status      String   @default("pending") // pending, completed, failed, refunded
  description String?
  metadata    String?  // JSON string for extra data
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SystemLog {
  id        String   @id @default(cuid())
  level     String   @default("info") // info, warning, error, critical
  category  String   @default("system") // system, auth, upload, api, security
  message   String
  details   String?  // JSON string for extra data
  userId    String?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())
}

model AdminSession {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  isActive  Boolean  @default(true)
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String
  updatedAt DateTime @updatedAt
}

model UploadSession {
  id          String   @id @default(cuid())
  fileName    String
  fileSize    BigInt
  mimeType    String
  chunkSize   Int      @default(5242880) // 5MB default chunk size
  totalChunks Int
  uploadedChunks String @default("[]") // JSON array of uploaded chunk indices
  status      String   @default("pending") // pending, uploading, processing, completed, failed
  videoId     String?  // linked video after completion
  storageKey  String?  // R2/local storage key
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
}
